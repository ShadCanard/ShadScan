<UserControl x:Class="ShadScan.Client.Fragments.Library.MenuLibraryFragment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShadScan.Client.Fragments.Library"
             xmlns:shad="clr-namespace:ShadDev.Core.NET.UserControls;assembly=ShadDev.Core.NET"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <shad:DescriptionComboBox x:Name="cbTreeViewType" Margin="5" SelectionChanged="OnSelectFilter" />
        <TreeView 
            x:Name="tvItem" 
            Margin="5" 
            BorderBrush="{DynamicResource MahApps.Brushes.Button.Border}" 
            BorderThickness="1" 
            Width="300" 
            Grid.Row="1" 
            SelectedItemChanged="OnSelectedItemTreeviewChange" 
        />
    </Grid>
</UserControl>
