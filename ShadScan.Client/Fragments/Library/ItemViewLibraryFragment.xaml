<UserControl x:Class="ShadScan.Client.Fragments.Library.ItemViewLibraryFragment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShadScan.Client.Fragments.Library"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:sdl="http://schemas.sdl.com/xaml"
             xmlns:converters="clr-namespace:ShadDev.Core.NET.Infrastructure.Converters;assembly=ShadDev.Core.NET"
             xmlns:model="clr-namespace:ShadScan.Client.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBooleanConverter x:Key="InvertBool" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Barre de navigation -->
        <Button Content="Retour"
                Click="OnReturnToLibraryClick"
                Margin="5"
                HorizontalAlignment="Left"
                />

        <!-- Informations du fichier -->
        <Grid MinWidth="200" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBox Text="{Binding Name, Mode=TwoWay}" 
                     Margin="5" 
                     IsReadOnly="True" 
                     controls:TextBoxHelper.UseFloatingWatermark="True" 
                     controls:TextBoxHelper.Watermark="Nom" />
            <TextBox Grid.Row="1" 
                     Margin="5" 
                     IsReadOnly="True" 
                     controls:TextBoxHelper.UseFloatingWatermark="True" 
                     controls:TextBoxHelper.Watermark="Auteur" 
                     Text="{Binding Author, Mode=TwoWay}" />
            <ComboBox Grid.Row="2" 
                      Margin="5" 
                      IsReadOnly="True" 
                      SelectedItem="{Binding Type, Mode=TwoWay}" />
            <sdl:MultiSelectComboBox x:Name="cbTypes" 
                                     Grid.Row="3" 
                                     Margin="5" 
                                     IsEnabled="False"
                                     SelectedItems="{Binding Tags, Mode=TwoWay}" />
            <TextBox Grid.Row="4" 
                     Margin="5" 
                     IsReadOnly="True" 
                     controls:TextBoxHelper.UseFloatingWatermark="True" 
                     controls:TextBoxHelper.Watermark="Date de création" 
                     Text="{Binding CreationTime, StringFormat='{}{0:dd\/MM\/yyyy HH:mm}', Mode=TwoWay}" />
            <TextBox Grid.Row="5" 
                     Margin="5" 
                     IsReadOnly="True" 
                     AcceptsReturn="True"
                     Height="100"
                     controls:TextBoxHelper.UseFloatingWatermark="True" 
                     controls:TextBoxHelper.Watermark="Description" 
                     Text="{Binding Description, Mode=TwoWay}" />
            <Button x:Name="btnEdit"
                    Content="Editer"
                    Grid.Row="7"
                    Margin="5"
                    Click="OnToggleEditMode"
                    />
        </Grid>

        <!-- Aperçu du fichier -->
        <Grid Grid.Column="1" Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Image Source="{Binding CurrentImage, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" Stretch="Uniform" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                <Button Visibility="{Binding ShowPreviousNextButtons, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}, Mode=OneWay}" 
                        Content="Précédent" 
                        Margin="5" 
                        IsEnabled="{Binding IsFirstPage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource  InvertBool}, Mode=OneWay}"
                        Click="OnPreviousClick" />
                
                <Button Content="Ouvrir" 
                        Margin="5" 
                        Click="OnOpenClick" />
                
                <Button Content="Imprimer" 
                        Margin="5" 
                        Click="OnPrintClick" />
                
                <Button Content="Délier la page" 
                        Margin="5" 
                        Visibility="{Binding ShowPreviousNextButtons, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}, Mode=OneWay}" 
                        Click="OnUnbindClick"
                        />
                <Button Visibility="{Binding ShowPreviousNextButtons, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}, Mode=OneWay}" 
                        Content="Suivant" 
                        Click="OnNextClick"
                        IsEnabled="{Binding IsLastPage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource  InvertBool}, Mode=OneWay}"
                        Margin="5" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
