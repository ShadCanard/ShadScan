<UserControl x:Class="ShadScan.Client.Fragments.Scan.ResultScanFragment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShadScan.Client.Fragments.Scan"
             xmlns:shad="clr-namespace:ShadDev.Core.NET.UserControls;assembly=ShadDev.Core.NET"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel x:Name="loading" Visibility="Hidden" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="txtStatus" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextAlignment="Center"/>
            <controls:ProgressRing x:Name="ProgressRing" />
        </StackPanel>
        <Image x:Name="imgPreview" Stretch="Uniform" Margin="5" Visibility="Hidden"/>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Center" Margin="5">
            <ComboBox Width="200">
                <ComboBoxItem Content="100 DPI (Preview)" />
            </ComboBox>
            <shad:DescriptionComboBox x:Name="cbxFileType" Width="200" Margin="10,0" />
            <Slider x:Name="sldDpi" Minimum="100" Maximum="800" TickFrequency="100" Width="200" Margin="10,0" Value="100" ValueChanged="OnChangeDPI" />
            <TextBlock x:Name="txtDpi" Text="100 DPI" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" />
            <Button x:Name="btnSave" Content="Enregistrer" Margin="5" Click="OnSave" />
        </StackPanel>
    </Grid>
</UserControl>
